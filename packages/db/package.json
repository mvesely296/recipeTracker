{
  "name": "@recipe-tracker/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@recipe-tracker/types": "workspace:*",
    "drizzle-orm": "^0.35.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@recipe-tracker/eslint-config": "workspace:*",
    "@recipe-tracker/typescript-config": "workspace:*",
    "drizzle-kit": "^0.27.0",
    "typescript": "^5.7.0"
  }
}
